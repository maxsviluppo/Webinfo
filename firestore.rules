rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (uid)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, 'user' or 'admin')
    //
    // Collection: favorites
    // Document ID: favoriteId (userId_newsId)
    // Fields:
    //   - userId: string (required)
    //   - newsId: string (required)
    //   - title: string (required)
    //   - summary: string (required)
    //   - category: string (required)
    //   - imageUrl: string (required)
    //   - url: string (required)
    //   - source: string (required)
    //   - createdAt: timestamp (required)
    //   - expiresAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "castromassimo@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() < 100 &&
             data.role in ['user', 'admin'];
    }

    function isValidFavorite(data) {
      return data.keys().hasAll(['userId', 'newsId', 'title', 'summary', 'category', 'imageUrl', 'url', 'source', 'createdAt', 'expiresAt']) &&
             data.userId == request.auth.uid &&
             data.newsId is string &&
             data.title is string && data.title.size() < 200 &&
             data.summary is string && data.summary.size() < 1000 &&
             data.category is string && data.category.size() < 100 &&
             data.imageUrl is string && data.imageUrl.size() < 500 &&
             data.url is string && data.url.size() < 500 &&
             data.source is string && data.source.size() < 100 &&
             data.createdAt is timestamp &&
             data.expiresAt is timestamp &&
             data.expiresAt > data.createdAt;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
    }

    match /favorites/{favoriteId} {
      // Allow reading only own favorites
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Allow creating only own favorites
      allow create: if isAuthenticated() && isValidFavorite(request.resource.data);
      
      // Allow deleting only own favorites
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // No updates allowed for favorites (they are atomic)
      allow update: if false;
    }
  }
}
