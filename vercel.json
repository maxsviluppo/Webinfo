{
  "version": 2,
  "functions": {
    "api/*.ts": {
      "includeFiles": ".data/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/ads.txt", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
